# Required — Devin API service-user key (prefix: cog_)
DEVIN_API_KEY=cog_...

# Required — Devin organization ID (prefix: org-)
DEVIN_ORG_ID=org-...

# Polling interval in seconds (default: 60)
POLL_INTERVAL_SECONDS=60

# How far back to look on first run when no checkpoint exists (seconds, default: 86400 = 24h)
LOOKBACK_SECONDS=86400

# Path to the JSON file that tracks the last-processed timestamp
STATE_FILE=.watcher_state.json

# Optional — user ID to impersonate when creating setup sessions
# CREATE_AS_USER_ID=google-oauth2|...

# Optional — maximum ACU budget per setup session (default: no limit)
# MAX_ACU_LIMIT=10

# Processing mode: "immediate" fires one session per repo as events arrive;
# "batch" collects repos over BATCH_WINDOW_SECONDS and fires one session per batch.
PROCESSING_MODE=immediate

# Batch window in seconds (only used when PROCESSING_MODE=batch)
BATCH_WINDOW_SECONDS=300

# Comma-separated repo URL substrings to ignore (e.g. "fork-playground,scratch-")
# IGNORE_PATTERNS=

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
